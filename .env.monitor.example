# ── Local monitor credentials ────────────────────────────────────────────
# Copy this file to .env.monitor and fill in values.
# .env.monitor is gitignored — never commit it.
#
# Used by: scripts/run_monitor.py
# Replaces: .github/workflows/monitor.yml (GHA cron)

# Dashboard
DASHBOARD_BASE_URL=https://tradegenius.up.railway.app
DASHBOARD_PASSWORD=

# Alpaca — per-portfolio paper keys
VAL_ALPACA_PAPER_KEY=
VAL_ALPACA_PAPER_SECRET=
GENE_ALPACA_PAPER_KEY=
GENE_ALPACA_PAPER_SECRET=
# Optional: main portfolio (falls back to val/gene creds if unset)
MAIN_ALPACA_PAPER_KEY=
MAIN_ALPACA_PAPER_SECRET=

# Railway — log tail via GraphQL API
# Token: https://railway.app/account/tokens (personal or project-scoped)
# Service UUID: Railway dashboard URL → project → service → copy UUID from URL
RAILWAY_API_TOKEN=
RAILWAY_SERVICE_ID=

# Telegram — invariant-failure alerts (same bot/chat as the bot uses)
TELEGRAM_TP_TOKEN=
TELEGRAM_TP_CHAT_ID=
