# ─────────────────────────────────────────────────────────────────────────────
# Stock Spike Monitor — Environment Variables (v3.5.0 paper-only)
# Copy this file to .env for local dev, or set these in Railway / your platform
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Telegram Bot Token — from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — the group/channel the bot posts to
# (use negative number for groups)
CHAT_ID=-your_chat_id_here

# Financial Modeling Prep API Key — powers PDC (Previous Day Close) lookup,
# which is the single polarity anchor for every entry/exit gate.
# Free tier at financialmodelingprep.com (250 calls/day)
FMP_API_KEY=your_fmp_key_here

# ── OWNER WHITELIST (required for Telegram control) ──────────────────────────
# Comma-separated Telegram user ids whitelisted by the v3.6.0 auth guard.
# Every Telegram update is checked against this list before any handler
# fires; non-owners are silently dropped (no reply, server-side log only).
# If unset, the built-in default owner id (Val) is used.
# v3.6.0 hard-renamed from RH_OWNER_USER_IDS — the old var is no longer read.
# TRADEGENIUS_OWNER_IDS=5165570192

# ── DASHBOARD (optional; bot runs without it) ────────────────────────────────

# Set DASHBOARD_PASSWORD to enable the dashboard server. If unset, the
# dashboard HTTP server does not start.
DASHBOARD_PASSWORD=your_strong_dashboard_password
DASHBOARD_PORT=8080
DASHBOARD_SESSION_SECRET=generate_a_random_64_char_string

# ── RISK GATE (optional) ─────────────────────────────────────────────────────

# Pause new entries once the paper portfolio's day P&L hits -$DAILY_LOSS_LIMIT.
# Leave unset to disable.
DAILY_LOSS_LIMIT=500

# ── PERSISTENCE PATHS (set if using Railway Volume) ──────────────────────────
# Mount a Railway Volume at /data, then set these paths:

# Paper trading portfolio state (positions, cash, trade log)
PAPER_STATE_PATH=/data/paper_state.json

# Paper trading investment log (all trade records)
PAPER_LOG_PATH=/data/investment.log

# Editable ticker universe (AAPL, MSFT, NVDA, TSLA, META, GOOG, AMZN, AVGO,
# QBTS, SPY, QQQ by default — edit via /ticker add|remove)
TICKERS_FILE=/data/tickers.json

# ── TESTING ──────────────────────────────────────────────────────────────────

# Set to "1" to short-circuit long-running network calls in smoke tests.
# Do NOT set in production.
# SSM_SMOKE_TEST=1

# ── TRADEGENIUS VAL (v4.0.0-alpha) ──────────────────────────────────────────
# Val is a Genius executor that mirrors main paper signals to Alpaca.
# Set VAL_ENABLED=0 to disable Val startup (default enabled if keys present).
VAL_ENABLED=1

# Alpaca paper keys (required for Val paper mode)
VAL_ALPACA_PAPER_KEY=your_alpaca_paper_key
VAL_ALPACA_PAPER_SECRET=your_alpaca_paper_secret

# Alpaca live keys (required ONLY if flipping to live via /mode val live confirm)
VAL_ALPACA_LIVE_KEY=
VAL_ALPACA_LIVE_SECRET=

# Val's own Telegram bot (separate from main)
VAL_TELEGRAM_TOKEN=your_val_bot_token
VAL_TELEGRAM_CHAT_ID=
VAL_TELEGRAM_OWNER_IDS=5165570192

# Dollar size per Val entry (default $10,000)
VAL_DOLLARS_PER_ENTRY=10000

# v5.1.4 — equity-aware sizing caps for the LIVE executor path.
# Each entry is sized as min(DOLLARS_PER_ENTRY,
#                            equity * MAX_PCT_PER_ENTRY/100,
#                            cash - MIN_RESERVE_CASH).
# Paper book sizing is unaffected.
# Max % of equity per single entry (cap on DOLLARS_PER_ENTRY).
# 10.0 means each entry is at most 10% of current Alpaca equity.
VAL_MAX_PCT_PER_ENTRY=10.0
# Cash floor that must remain after each entry (USD).
VAL_MIN_RESERVE_CASH=500

# Optional endpoint overrides (default uses alpaca-py's built-in URLs)
# ALPACA_ENDPOINT_PAPER=https://paper-api.alpaca.markets
# ALPACA_ENDPOINT_TRADE=https://api.alpaca.markets

# ── TRADEGENIUS GENE (v4.0.0-beta) ──────────────────────────────────────────
# Gene is a second Genius executor, identical to Val with GENE_ env prefix.
# Set GENE_ENABLED=0 to disable Gene startup (default enabled if keys present).
GENE_ENABLED=1

GENE_ALPACA_PAPER_KEY=
GENE_ALPACA_PAPER_SECRET=
GENE_ALPACA_LIVE_KEY=
GENE_ALPACA_LIVE_SECRET=
GENE_TELEGRAM_TOKEN=
GENE_TELEGRAM_CHAT_ID=
GENE_TELEGRAM_OWNER_IDS=5165570192
GENE_DOLLARS_PER_ENTRY=10000
# v5.1.4 — equity-aware sizing caps (LIVE executor path only).
GENE_MAX_PCT_PER_ENTRY=10.0
GENE_MIN_RESERVE_CASH=500

# ── DI SEEDING (v4.0.2-beta) ─────────────────────────────────────────────────
# At scanner startup the bot pulls recent 5m bars from Alpaca so the DI gate
# (DI+ ≥ 25 on 5m, period 15) is armed on the first scan cycle rather than
# waiting ~70 min of live RTH for the buffer to warm up naturally.
#
# DI_PREMARKET_SEED controls whether today's premarket bars (04:00–09:30 ET)
# are included in the seed stream.
#   "1" (default) — seed uses today-RTH + today-premarket + (fallback) prior-day-RTH
#   "0"           — seed skips premarket; uses today-RTH + prior-day-RTH only
# Kill switch in case premarket noise degrades DI signal quality.
DI_PREMARKET_SEED=1

# ── DO NOT SET ───────────────────────────────────────────────────────────────
# TZ — do NOT set this; the bot uses pytz internally and setting TZ breaks
# scheduling.
