# ─────────────────────────────────────────────────────────────────────────────
# Stock Spike Monitor — Environment Variables
# Copy this file to .env for local dev, or set these in Railway / your platform
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Telegram Bot Token — from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — the group/channel the bot posts to (use negative number for groups)
CHAT_ID=-your_chat_id_here

# Finnhub API Token — primary market data source (free tier at finnhub.io)
FINNHUB_TOKEN=your_finnhub_token_here

# Anthropic API Key — primary AI engine (claude.ai/api-keys)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── OPTIONAL BUT RECOMMENDED ─────────────────────────────────────────────────

# Grok API Key — fallback AI when Anthropic unavailable (console.x.ai)
GROK_API_KEY=xai-your_grok_key_here

# Financial Modeling Prep API Key — powers /movers, /earnings, /macro
# Free tier at financialmodelingprep.com (250 calls/day)
FMP_API_KEY=your_fmp_key_here

# ── PERSISTENCE PATHS (set these if using Railway Volume) ────────────────────
# Mount a Railway Volume at /data, then set these paths:

# Paper trading portfolio state (positions, cash, trade log)
PAPER_STATE_PATH=/data/paper_state.json

# Paper trading investment log (all trade records)
PAPER_LOG_PATH=/data/investment.log

# Bot state (watchlists, alerts, conversation history, tickers)
BOT_STATE_PATH=/data/bot_state.json

# ── DO NOT SET ────────────────────────────────────────────────────────────────
# TZ — do NOT set this; the bot uses pytz CT internally and setting TZ breaks scheduling
