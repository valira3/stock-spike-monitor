# ─────────────────────────────────────────────────────────────────────────────
# Stock Spike Monitor — Environment Variables
# Copy this file to .env for local dev, or set these in Railway / your platform
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Telegram Bot Token — main bot, from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — the group/channel the main bot posts to
# (use negative number for groups)
CHAT_ID=-your_chat_id_here

# Finnhub API Token — used for the SPY polarity quote path
# Free tier at finnhub.io
FINNHUB_TOKEN=your_finnhub_token_here

# Financial Modeling Prep API Key — powers PDC (Previous Day Close) lookup,
# which is the single polarity anchor for every entry/exit gate.
# Free tier at financialmodelingprep.com (250 calls/day)
FMP_API_KEY=your_fmp_key_here

# ── TRADERSPOST MIRROR (optional, enables live trading) ──────────────────────

# Flip to "true" to mirror every paper trade to TradersPost
TRADERSPOST_ENABLED=false

# TradersPost webhook URL — where the bot posts BUY/SELL/SHORT/COVER signals
TRADERSPOST_WEBHOOK_URL=https://traderspost.io/trading/webhook/your_webhook_id

# Separate Telegram bot that announces TP fills (optional; if unset, the main
# bot announces them instead)
TELEGRAM_TP_TOKEN=your_tp_bot_token_here
TELEGRAM_TP_CHAT_ID=-your_tp_chat_id_here

# ── ROBINHOOD MODE (live trading via TradersPost -> Robinhood) ──────────────
RH_STARTING_CAPITAL=25000
RH_DOLLARS_PER_ENTRY=1500
RH_MAX_ENTRIES_PER_TICKER=1
RH_MAX_CONCURRENT_POSITIONS=6
RH_LONG_ONLY=true

# ── GMAIL IMAP RECONCILIATION (optional; reads TradersPost fill/reject emails)
# Generate an app password at myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
RH_IMAP_POLL_SEC=120

# ── DASHBOARD (optional; bot runs without it) ────────────────────────────────

# Set DASHBOARD_PASSWORD to enable the dashboard server. If unset, the
# dashboard HTTP server does not start.
DASHBOARD_PASSWORD=your_strong_dashboard_password
DASHBOARD_PORT=8080
DASHBOARD_SESSION_SECRET=generate_a_random_64_char_string

# ── RISK GATE (optional) ─────────────────────────────────────────────────────

# Pause new entries once the paper portfolio's day P&L hits -$DAILY_LOSS_LIMIT.
# Leave unset to disable.
DAILY_LOSS_LIMIT=500

# ── PERSISTENCE PATHS (set if using Railway Volume) ──────────────────────────
# Mount a Railway Volume at /data, then set these paths:

# Paper trading portfolio state (positions, cash, trade log)
PAPER_STATE_PATH=/data/paper_state.json

# Paper trading investment log (all trade records)
PAPER_LOG_PATH=/data/investment.log

# Editable 9-ticker universe (AAPL, MSFT, NVDA, TSLA, META, GOOG, AMZN, AVGO,
# QBTS by default — edit via /ticker add|remove)
TICKERS_FILE=/data/tickers.json

# ── TESTING ──────────────────────────────────────────────────────────────────

# Set to "1" to short-circuit long-running network calls in smoke tests.
# Do NOT set in production.
# SSM_SMOKE_TEST=1

# ── DO NOT SET ───────────────────────────────────────────────────────────────
# TZ — do NOT set this; the bot uses pytz CT internally and setting TZ breaks
# scheduling.
