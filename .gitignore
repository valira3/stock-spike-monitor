# Claude Code harness local state — scheduler lock + ephemeral cache.
# Skills, settings, and commands remain tracked (.claude/skills/, .claude/settings*.json).
.claude/scheduled_tasks.lock
.claude/projects/
replay_week.html
data/.bt_cache/
data/ui_audit/
