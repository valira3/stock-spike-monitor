data/snapshots/
# Corpus protection (2026-05-19): rth-expand branch has 3,150 corpus dates
# main does not. Without this rule, a checkout of rth-expand into the working
# tree shows those dates as untracked, and `git add` sweeps them in (PR #799
# mishap). Tracked dates already in main keep tracking — gitignore only
# affects untracked files.
data/20*/
results/*
!results/keystone/
results/keystone/*
!results/keystone/keystone.json
!results/bench/
results/bench/*
!results/bench/*.md
CODE_REVIEW.md
.env
.env.monitor
.env.monitor.*

*.log
dashboard_secret.key
paper_state.json
debug_replay.py
trade_log.jsonl
paper_state_main.json
data/snapshots/

# Broad-universe research data — too large to commit
data_pm_universe/
data_broad/
data_rth_expand/

# OS noise picked up on the macOS dev machine
.DS_Store
*.webloc
